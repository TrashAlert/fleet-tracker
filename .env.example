APP_NAME="Fleet Tracker"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fleet_tracker
DB_USERNAME=root
DB_PASSWORD=

# MQTT Broker Configuration
MQTT_HOST=127.0.0.1
MQTT_PORT=8883
MQTT_TLS=true
MQTT_CA_CERT=/etc/mosquitto/certs/ca.crt
MQTT_CLIENT_CERT=/etc/mosquitto/certs/server.crt
MQTT_CLIENT_KEY=/etc/mosquitto/certs/server.key
MQTT_USERNAME=fleet_server
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=fleet/

# Mail (for delay notifications)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@fleettracker.local"
MAIL_FROM_NAME="${APP_NAME}"

# GPS Settings
GPS_OVERSPEED_THRESHOLD=110
GPS_DELAY_THRESHOLD_MINUTES=15
GPS_STALE_TIMEOUT_SECONDS=60
